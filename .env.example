# ============================================================
# DATABASE (PostgreSQL / DBaaS)
# ============================================================
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=portal_pegawai
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true

# ============================================================
# OBJECT STORAGE (AWS S3 / Compatible)
# Ganti dengan kredensial provider Anda:
#   - AWS S3         : region us-east-1, endpoint kosong
#   - IDCloudHost    : endpoint https://is3.cloudhost.id
#   - Cloudflare R2  : endpoint https://<account>.r2.cloudflarestorage.com
#   - MinIO lokal    : endpoint http://localhost:9000
# ============================================================
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=portal-pegawai-bucket
S3_REGION=ap-southeast-1
S3_ENDPOINT=https://your-object-storage-endpoint.com
# URL publik file (tanpa trailing slash). Contoh:
#   https://portal-pegawai-bucket.s3.ap-southeast-1.amazonaws.com
#   https://is3.cloudhost.id/portal-pegawai-bucket
S3_PUBLIC_URL=https://your-bucket-public-url.com

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_NAME=Portal Pendaftaran Pegawai
